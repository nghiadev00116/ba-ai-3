# ==========================================
# CẤU HÌNH HỆ THỐNG RAG VÀ CHATBOT
# Đổi tên file này thành .env hoặc copy nội dung sang file .env
# ==========================================

# --- GEMINI (LLM) ---
# Khóa API để gọi Gemini. Lấy tại: https://aistudio.google.com/app/apikey 
# (Bắt buộc phải có để hệ thống hoạt động)
GEMINI_API_KEY=your_gemini_api_key_here

# Tên mô hình Gemini sử dụng để tổng hợp câu trả lời 
# (Mặc định: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Giới hạn số token đầu vào gửi lên Gemini. Nếu vượt quá, các đoạn văn bản trích xuất sẽ bị cắt giảm để tránh lỗi.
# Phụ thuộc vào model, giới hạn của bản Flash thường trên 1.000.000 tokens.
# (Mặc định: 800000)
# GEMINI_MAX_TOKENS=800000


# --- QUẢN LÝ LỊCH SỬ CHAT (SESSION HISTORY) ---
# Số lượng tin nhắn tối đa (bao gồm cả hỏi và đáp) sẽ được lưu lại cho mỗi session.
# Hệ thống sẽ dựa vào tin nhắn cũ để hiểu các đại từ nhân xưng như "nó", "loại kia".
# Nếu thiết lập là 20, nghĩa là nhớ 10 vòng lặp (1 hỏi + 1 đáp) gần nhất. 
# (Mặc định: 20)
MAX_HISTORY_MESSAGES=20

# Số phút tối đa giữ lịch sử chat trên máy chủ kể từ lần tương tác cuối cùng của user đó.
# Khi quá thời gian này mà user không nhắn gì thêm, phiên chat tự động giải phóng bộ nhớ.
# (Mặc định: 10)
SESSION_EXPIRY_MINUTES=10


# --- CẤU HÌNH FASTAPI SERVER ---
# Địa chỉ Host của máy chủ. Để 127.0.0.1 khi code nội bộ, để 0.0.0.0 khi cho server thật chạy ngoài Internet.
# (Mặc định: 127.0.0.1)
SERVER_HOST=127.0.0.1

# Cổng truy cập của API
# (Mặc định: 8000)
SERVER_PORT=8000


# --- TÌM KIẾM VECTOR VÀ FAISS (RAG) ---
# Tên mô hình nhúng (Embedding) sử dụng để biến văn bản thành vector.
# Quan trọng: Nếu đổi mô hình, bạn bắt buộc phải tạo lại Index (chạy nút /rebuild).
# (Mặc định: BAAI/bge-m3)
EMBEDDING_MODEL=BAAI/bge-m3

# Độ dài mỗi "đoạn nhỏ" (chunk) khi cắt file PDF/DOCX (tính bằng số từ).
# Nên để từ 200 - 500 từ tuỳ thuộc vào ngữ cảnh.
# (Mặc định: 200)
CHUNK_SIZE=200

# Top K: Số lượng đoạn văn bản (chunks) gần đúng (tương đồng) nhất mà công cụ tìm kiếm FAISS nhặt ra gửi cho Gemini đọc.
# Lấy ít thì Gemini thiếu ý, lấy nhiều thì tốn Token.
# (Mặc định: 20)
DEFAULT_TOP_K=20

# Vùng ngưỡng để FAISS quyết định "đoạn này có giống với từ khóa tìm kiếm hay không".
# Tính theo phép Cosine Similarity chạy từ 0 đến 1. 0.35 là mức an toàn.
# (Mặc định: 0.35)
DEFAULT_THRESHOLD=0.35
